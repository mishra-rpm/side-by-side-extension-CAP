{
  "name": "incident-management",
  "version": "1.0.0",
  "dependencies": {
    "@sap/cds": "^9"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "cds-plugin-ui5": "^0.17.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-incidentmanagementapp": "cds watch --open ns.incidentmanagementapp/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "cds": {
    "requires": {
      "[development]":{
        "auth":{
          "kind": "mocked",
          "users": {
            "alice":{"roles": ["support"]},
            "bob":{"roles": ["admin"]}
          }
        }
      }
    }
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/incidentmanagementapp"
  ]
}
